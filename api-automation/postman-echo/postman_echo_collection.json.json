  "item": [
    {
      "name": "{{base_url}}/get",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response time < 800ms\", () => {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(800);\r",
              "});\r",
              "\r",
              "const jsonData = pm.response.json();\r",
              "\r",
              "pm.test(\"Query params returned correctly\", () => {\r",
              "    pm.expect(jsonData.args.name).to.eql(\"Cynthia\");\r",
              "    pm.expect(jsonData.args.job).to.eql(\"QA\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/get?name=Cynthia&job=QA",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "get"
          ],
          "query": [
            {
              "key": "name",
              "value": "Cynthia"
